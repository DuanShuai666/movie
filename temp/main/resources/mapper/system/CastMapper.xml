<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CastMapper">
    
    <resultMap type="Cast" id="CastResult">
        <result property="movieId"    column="movie_id"    />
        <result property="personId"    column="person_id"    />
        <result property="character"    column="character"    />
        <result property="order"    column="order"    />
    </resultMap>

    <sql id="selectCastVo">
        select movie_id, person_id, character, order from cast
    </sql>

    <select id="selectCastList" parameterType="Cast" resultMap="CastResult">
        <include refid="selectCastVo"/>
        <where>  
            <if test="character != null  and character != ''"> and character = #{character}</if>
            <if test="order != null "> and order = #{order}</if>
        </where>
    </select>
    
    <select id="selectCastByMovieId" parameterType="Long" resultMap="CastResult">
        <include refid="selectCastVo"/>
        where movie_id = #{movieId}
    </select>

    <insert id="insertCast" parameterType="Cast">
        insert into cast
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="movieId != null">movie_id,</if>
            <if test="personId != null">person_id,</if>
            <if test="character != null">character,</if>
            <if test="order != null">order,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="movieId != null">#{movieId},</if>
            <if test="personId != null">#{personId},</if>
            <if test="character != null">#{character},</if>
            <if test="order != null">#{order},</if>
         </trim>
    </insert>

    <update id="updateCast" parameterType="Cast">
        update cast
        <trim prefix="SET" suffixOverrides=",">
            <if test="personId != null">person_id = #{personId},</if>
            <if test="character != null">character = #{character},</if>
            <if test="order != null">order = #{order},</if>
        </trim>
        where movie_id = #{movieId}
    </update>

    <delete id="deleteCastByMovieId" parameterType="Long">
        delete from cast where movie_id = #{movieId}
    </delete>

    <delete id="deleteCastByMovieIds" parameterType="String">
        delete from cast where movie_id in 
        <foreach item="movieId" collection="array" open="(" separator="," close=")">
            #{movieId}
        </foreach>
    </delete>
</mapper>