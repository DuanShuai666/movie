<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MovieGenreMapper">
    
    <resultMap type="MovieGenre" id="MovieGenreResult">
        <result property="movieId"    column="movie_id"    />
        <result property="genreId"    column="genre_id"    />
    </resultMap>

    <sql id="selectMovieGenreVo">
        select movie_id, genre_id from movie_genre
    </sql>

    <select id="selectMovieGenreList" parameterType="MovieGenre" resultMap="MovieGenreResult">
        <include refid="selectMovieGenreVo"/>
        <where>  
        </where>
    </select>
    
    <select id="selectMovieGenreByMovieId" parameterType="Long" resultMap="MovieGenreResult">
        <include refid="selectMovieGenreVo"/>
        where movie_id = #{movieId}
    </select>

    <insert id="insertMovieGenre" parameterType="MovieGenre">
        insert into movie_genre
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="movieId != null">movie_id,</if>
            <if test="genreId != null">genre_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="movieId != null">#{movieId},</if>
            <if test="genreId != null">#{genreId},</if>
         </trim>
    </insert>

    <update id="updateMovieGenre" parameterType="MovieGenre">
        update movie_genre
        <trim prefix="SET" suffixOverrides=",">
            <if test="genreId != null">genre_id = #{genreId},</if>
        </trim>
        where movie_id = #{movieId}
    </update>

    <delete id="deleteMovieGenreByMovieId" parameterType="Long">
        delete from movie_genre where movie_id = #{movieId}
    </delete>

    <delete id="deleteMovieGenreByMovieIds" parameterType="String">
        delete from movie_genre where movie_id in 
        <foreach item="movieId" collection="array" open="(" separator="," close=")">
            #{movieId}
        </foreach>
    </delete>
</mapper>