<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.DirectorMapper">
    
    <resultMap type="Director" id="DirectorResult">
        <result property="movieId"    column="movie_id"    />
        <result property="personId"    column="person_id"    />
    </resultMap>

    <sql id="selectDirectorVo">
        select movie_id, person_id from director
    </sql>

    <select id="selectDirectorList" parameterType="Director" resultMap="DirectorResult">
        <include refid="selectDirectorVo"/>
        <where>  
        </where>
    </select>
    
    <select id="selectDirectorByMovieId" parameterType="Long" resultMap="DirectorResult">
        <include refid="selectDirectorVo"/>
        where movie_id = #{movieId}
    </select>

    <insert id="insertDirector" parameterType="Director">
        insert into director
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="movieId != null">movie_id,</if>
            <if test="personId != null">person_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="movieId != null">#{movieId},</if>
            <if test="personId != null">#{personId},</if>
         </trim>
    </insert>

    <update id="updateDirector" parameterType="Director">
        update director
        <trim prefix="SET" suffixOverrides=",">
            <if test="personId != null">person_id = #{personId},</if>
        </trim>
        where movie_id = #{movieId}
    </update>

    <delete id="deleteDirectorByMovieId" parameterType="Long">
        delete from director where movie_id = #{movieId}
    </delete>

    <delete id="deleteDirectorByMovieIds" parameterType="String">
        delete from director where movie_id in 
        <foreach item="movieId" collection="array" open="(" separator="," close=")">
            #{movieId}
        </foreach>
    </delete>
</mapper>